{
    "manifest_version": 3,
    "name": "MatugenFox",
    "version": "2.0.2",
    "description": "Dynamic webpage and browser theming using Matugen colors",
    "homepage_url": "https://github.com/Ubaidullah-Web-Dev/MatugenFox",
    "browser_specific_settings": {
        "gecko": {
            "id": "matugenfox@ubaid.com",
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            }
        }
    },
    "permissions": [
        "nativeMessaging",
        "storage",
        "tabs",
        "scripting",
        "menus",
        "theme"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "scripts": [
            "background.js"
        ]
    },
    "icons": {
        "16": "icons/icon-16.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "MatugenFox",
        "default_icon": "icons/icon-48.png",
        "browser_style": false
    },
    "options_ui": {
        "page": "options.html",
        "open_in_tab": true,
        "browser_style": false
    },
    "commands": {
        "toggle-theming": {
            "suggested_key": {
                "default": "Ctrl+Shift+M"
            },
            "description": "Toggle MatugenFox theming on/off"
        },
        "toggle-pause": {
            "description": "Pause/resume MatugenFox for 10 minutes"
        },
        "reapply-theme": {
            "description": "Reapply theme to active tab"
        },
        "fetch-theme": {
            "description": "Re-fetch Matugen colors from native host"
        },
        "disable-theme": {
            "description": "Disable all theming (web pages + browser chrome)"
        },
        "enable-dark-mode": {
            "description": "Enable dark theme mode"
        },
        "enable-light-mode": {
            "description": "Enable light theme mode"
        },
        "enable-auto-mode": {
            "description": "Enable automatic dark/light mode based on time"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_start"
        },
        {
            "matches": [
                "*://*.duckduckgo.com/*"
            ],
            "js": [
                "duckduckgo.js"
            ],
            "run_at": "document_end"
        }
    ]
}
[Desktop Entry]
Type=Application
Name=Dusky Input TUI
GenericName=Input Configurator
Comment=Real-time Hyprland input, mouse, and gesture configurator
Exec=foot --app-id=dusky_tui python3 /home/dusk/user_scripts/hypr/input/tui_input.py
Terminal=false
Categories=Settings;DesktopSettings;System;Utility;
Keywords=dusky;hyprland;input;mouse;keyboard;touchpad;gestures;tui;config;settings;
Icon=preferences-desktop-keyboard
StartupNotify=true
StartupWMClass=dusky_input.sh
